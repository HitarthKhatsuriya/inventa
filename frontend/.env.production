# ── Production API URL ──────────────────────────────────────────────────────
# Replace this with your actual deployed Laravel backend URL.
# Examples:
#   https://mediq-api.onrender.com
#   https://mediq-api.railway.app
#   https://api.mediq.yourdomain.com
#
# IMPORTANT: Do NOT include a trailing slash.
# You can also set this in Netlify Dashboard → Site Settings → Environment Variables
# as VITE_API_URL (which overrides this file).

VITE_API_URL=https://your-backend-url.onrender.com
